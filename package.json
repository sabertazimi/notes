{
  "name": "notes",
  "version": "1.1.0",
  "packageManager": "pnpm@10.33.0",
  "description": "Personal Learning Notes (TIL)",
  "author": "sabertazimi",
  "license": "MIT",
  "homepage": "https://github.com/sabertazimi/notes#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sabertazimi/notes.git"
  },
  "bugs": {
    "url": "https://github.com/sabertazimi/notes/issues"
  },
  "keywords": [
    "Docusaurus",
    "Notes",
    "CS",
    "AI",
    "Agent",
    "Claude Code",
    "Skills",
    "HTML",
    "CSS",
    "JavaScript",
    "TypeScript",
    "React",
    "Web",
    "TIL"
  ],
  "main": "README.md",
  "scripts": {
    "build": "docusaurus build && cp -rf vercel.json build/",
    "clone": "git clone https://$VERCEL_GIT_PROVIDER.com/$VERCEL_GIT_REPO_OWNER/$VERCEL_GIT_REPO_SLUG && rm -fr .git && cp -fr $VERCEL_GIT_REPO_SLUG/.git . && rm -fr $VERCEL_GIT_REPO_SLUG",
    "clear": "docusaurus clear",
    "dev": "docusaurus start",
    "lint": "npm-run-all --parallel lint:content lint:code lint:types",
    "lint:content": "npm-run-all --parallel lint:content:eslint lint:content:stylelint lint:content:markdownlint",
    "lint:content:eslint": "eslint ./content",
    "lint:content:stylelint": "stylelint ./content/**/*.md",
    "lint:content:markdownlint": "markdownlint-cli2 './content/**/*.md'",
    "lint:code": "npm-run-all --parallel lint:code:eslint lint:code:stylelint",
    "lint:code:eslint": "eslint ./src",
    "lint:code:stylelint": "stylelint ./src/**/*.css",
    "lint:types": "tsc --noEmit",
    "lint:fix": "npm-run-all --parallel lint:content:fix lint:code:fix",
    "lint:content:fix": "npm-run-all --parallel lint:content:eslint:fix lint:content:stylelint:fix lint:content:markdownlint:fix",
    "lint:content:eslint:fix": "eslint ./content --fix",
    "lint:content:stylelint:fix": "stylelint ./content/**/*.md --fix",
    "lint:content:markdownlint:fix": "markdownlint-cli2 './content/**/*.md' --fix",
    "lint:code:fix": "npm-run-all --parallel lint:code:eslint:fix lint:code:stylelint:fix",
    "lint:code:eslint:fix": "eslint ./src --fix",
    "lint:code:stylelint:fix": "stylelint ./src/**/*.css --fix",
    "format": "prettier --write",
    "changeset": "commit-and-tag-version --dry-run -s",
    "release": "commit-and-tag-version -s",
    "serve": "docusaurus serve",
    "prepare": "husky",
    "oj": "vitest",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.0",
    "@docusaurus/faster": "^3.10.0",
    "@docusaurus/preset-classic": "^3.10.0",
    "@docusaurus/theme-mermaid": "^3.10.0",
    "@easyops-cn/docusaurus-search-local": "^0.55.1",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "katex": "^0.16.45",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@dg-scripts/eslint-config": "^6.1.1",
    "@dg-scripts/stylelint-config": "^6.1.1",
    "@docusaurus/module-type-aliases": "^3.10.0",
    "@docusaurus/theme-classic": "^3.10.0",
    "@docusaurus/tsconfig": "^3.10.0",
    "@docusaurus/types": "^3.10.0",
    "@mdx-js/react": "^3.1.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.4",
    "c8": "^11.0.0",
    "ci-info": "^4.4.0",
    "commit-and-tag-version": "^12.7.1",
    "consola": "^3.4.2",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "stylelint": "^17.8.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
